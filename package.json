{
  "name": "netzwerkplan",
  "version": "1.0.6",
  "description": "Desktop-App zum Erstellen und Exportieren von Netzwerkplaenen.",
  "main": "src/main.js",
  "scripts": {
    "clean:release": "node scripts/clean-release.js",
    "desktop": "electron .",
    "build": "npm run clean:release && electron-builder",
    "build:win": "npm run clean:release && electron-builder --win",
    "build:mac": "npm run clean:release && electron-builder --mac",
    "build:linux": "npm run clean:release && electron-builder --linux"
  },
  "keywords": [
    "network",
    "diagram",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/indextorben/Netzwerkplan.git"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "de.netzwerkplan.app",
    "productName": "Netzwerkplan",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "indextorben",
        "repo": "Netzwerkplan"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
